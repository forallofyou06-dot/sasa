        // --- 7. AIとのインタラクティブチャット (Gemini 2.5 Flash API 実装) ---
        function handleChatEnter(event) {
            if (event.key === 'Enter') {
                sendChatMessage();
            }
        }

        // 問い合わせへジャンプし、AIに入力したチャット内容を自動プレフィルする関数
        function goToInquiryForm(prefillMsg) {
            document.getElementById('form-detail').value = prefillMsg;
            switchTab('form', '新規問い合わせ');
        }

        // 指数バックオフ機能付きフェッチ
        async function fetchWithRetry(url, options, retries = 5, delay = 1000) {
            try {
                const response = await fetch(url, options);
                if (!response.ok) throw new Error(`HTTP error! status: ${response.status}`);
                return await response.json();
            } catch (error) {
                if (retries === 0) throw error;
                await new Promise(resolve => setTimeout(resolve, delay));
                return fetchWithRetry(url, options, retries - 1, delay * 2);
            }
        }

        async function sendChatMessage() {
            const input = document.getElementById('chat-input-text');
            const message = input.value.trim();
            if (!message) return;

            const chatBox = document.getElementById('chat-box');

            // 現在時刻文字列の取得
            const now = new Date();
            const timeStr = `本日 ${String(now.getHours()).padStart(2, '0')}:${String(now.getMinutes()).padStart(2, '0')}`;

            // ユーザー吹き出しの追加
            const userBubble = `
                <div class="chat-bubble user">
                    ${message}
                    <div class="chat-time">${timeStr}</div>
                </div>
            `;
            chatBox.innerHTML += userBubble;
            input.value = '';

            // スクロールを最下部に固定
            chatBox.scrollTop = chatBox.scrollHeight;

            // ローディングインジケーターの追加
            const loadingId = "loading-" + Date.now();
            const loadingBubble = `
                <div class="chat-bubble bot loading" id="${loadingId}">
                    <span>✨ AIが回答を考え中...</span>
                    <div class="loader-dots">
                        <span></span>
                        <span></span>
                        <span></span>
                    </div>
                </div>
            `;
            chatBox.innerHTML += loadingBubble;
            chatBox.scrollTop = chatBox.scrollHeight;

            // --- Gemini API連携パラメータ設計 ---
            const apiKey = ""; // 実行環境からAPIキーが注入されます
            const url = `https://genergenerativelanguage.googleapis.com/v1beta/models/gemini-2.5-flash-preview-09-2025:generateContent?key=${apiKey}`.replace('genergenerative', 'generative');

            const systemPrompt = `
あなたは「AI×プロダクト開発研修」のお問い合わせアシスタントです。
以下の【よくある質問データベース】に登録されている情報だけを参照して、ユーザーの質問に回答してください。

【よくある質問データベース】
${JSON.stringify(faqDatabase, null, 2)}

【ルール】
1. ユーザーの質問に対し、データベースの中に明確に合致する回答がある場合のみ、その情報を正確に回答してください。
2. データベースに存在しない情報や、少しでも曖昧・記述のない質問に関しては、絶対に推測で答えたり適当な文章を作ったりせず（ハルシネーションを防止するため）、必ず以下の文章「のみ」を回答として出力してください。
「申し訳ありません、その質問に関するデータはデータベースにありません。担当者にお問い合わせください。」
`;

            try {
                const responseData = await fetchWithRetry(url, {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify({
                        contents: [{ parts: [{ text: message }] }],
                        systemInstruction: { parts: [{ text: systemPrompt }] }
                    })
                });

                // ローディングの削除
                const loadingElement = document.getElementById(loadingId);
                if (loadingElement) loadingElement.remove();

                const aiReplyText = responseData.candidates?.[0]?.content?.parts?.[0]?.text?.trim() || "申し訳ありません、応答の解析に失敗しました。";

                let botBubbleHtml = '';

                // もし「データベースにありません」という文言が含まれる場合は、問い合わせボタンを出す
                if (aiReplyText.includes("データベースにありません")) {
                    const escapedMsg = message.replace(/'/g, "\\'").replace(/"/g, '&quot;');
                    botBubbleHtml = `
                        <div class="chat-bubble bot">
                            申し訳ありません、その質問に関するデータはデータベースにありません。お手数ですが、担当者へ直接お問い合わせいただけますでしょうか。<br>
                            <div class="direct-inquiry-box">
                                <button class="btn-direct-link" onclick="goToInquiryForm('${escapedMsg}')">
                                    ✨ 問い合わせフォームへ進む
                                </button>
                            </div>
                            <div class="chat-time">${timeStr}</div>
                        </div>
                    `;
                } else {
                    botBubbleHtml = `
                        <div class="chat-bubble bot">
                            ${aiReplyText.replace(/\n/g, '<br>')}
                            <div class="chat-time">${timeStr}</div>
                        </div>
                    `;
                }

                chatBox.innerHTML += botBubbleHtml;
                chatBox.scrollTop = chatBox.scrollHeight;

            } catch (error) {
                // ローディングの削除
                const loadingElement = document.getElementById(loadingId);
                if (loadingElement) loadingElement.remove();

                // エラー時の処理 (安全なローカル簡易自動マッチを代替発火)
                const lowerMsg = message.toLowerCase();
                let matchedFaq = null;

                if (lowerMsg.includes('誰') || lowerMsg.includes('対象') || lowerMsg.includes('参加')) {
                    matchedFaq = faqDatabase.find(f => f.id === "F001");
                } else if (lowerMsg.includes('学ぶ') || lowerMsg.includes('内容') || lowerMsg.includes('プロダクト開発')) {
                    matchedFaq = faqDatabase.find(f => f.id === "F002");
                } else if (lowerMsg.includes('未経験') || lowerMsg.includes('初心者') || lowerMsg.includes('スキル')) {
                    matchedFaq = faqDatabase.find(f => f.id === "F003");
                } else if (lowerMsg.includes('期間') || lowerMsg.includes('日程') || lowerMsg.includes('スケジュール')) {
                    matchedFaq = faqDatabase.find(f => f.id === "F004");
                }

                let botBubbleHtml = '';
                if (matchedFaq) {
                    botBubbleHtml = `
                        <div class="chat-bubble bot">
                            【${matchedFaq.category}に関して】<br>
                            ${matchedFaq.body}
                            <div class="chat-time">${timeStr}</div>
                        </div>
                    `;
                } else {
                    const escapedMsg = message.replace(/'/g, "\\'").replace(/"/g, '&quot;');
                    botBubbleHtml = `
                        <div class="chat-bubble bot">
                            申し訳ありません、その質問に関するデータはデータベースにありません。お手数ですが、担当者へ直接お問い合わせいただけますでしょうか。<br>
                            <div class="direct-inquiry-box">
                                <button class="btn-direct-link" onclick="goToInquiryForm('${escapedMsg}')">
                                    ✨ 問い合わせフォームへ進む
                                </button>
                            </div>
                            <div class="chat-time">${timeStr}</div>
                        </div>
                    `;
                }

                chatBox.innerHTML += botBubbleHtml;
                chatBox.scrollTop = chatBox.scrollHeight;
            }
        }

        // ページロード時の初期レンダリング
        window.addEventListener('DOMContentLoaded', () => {
            renderHistoryList();
        });
    </script>
