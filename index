        // --- 2. 画面切り替えとタブ制御 ---
        function switchTab(screenId, titleText) {
            // スクリーンの切り替え
            document.querySelectorAll('.screen').forEach(screen => {
                screen.classList.remove('active');
            });
            document.getElementById(`screen-${screenId}`).classList.add('active');

            // ヘッダーのテキスト変更
            document.getElementById('main-header').innerText = titleText;

            // タブのアクティブクラス更新
            document.querySelectorAll('.nav-tab').forEach(tab => {
                tab.classList.remove('active');
            });
            document.querySelector(`.nav-tab[data-screen="${screenId}"]`).classList.add('active');

            // 画面切り替え時にスクロール最上部に戻す
            document.getElementById('scroll-wrapper').scrollTop = 0;
        }

        // --- 3. FAQアコーディオン開閉制御 ---
        function toggleFaq(cardElement) {
            const isOpen = cardElement.classList.contains('open');
            
            // すべてのアコーディオンを一度閉じる
            document.querySelectorAll('.faq-card').forEach(card => {
                card.classList.remove('open');
            });

            // 閉じていたものを開く
            if (!isOpen) {
                cardElement.classList.add('open');
            }
        }

        // --- 4. 履歴画面のダイナミックレンダリング ---
        function renderHistoryList() {
            const container = document.getElementById('history-container');
            container.innerHTML = ''; // クリア

            inquiryDatabase.forEach((item, index) => {
                // カテゴリに応じたアイコンとカラーバッジの設定
                let badgeClass = 'badge-other';
                let catLabelClass = 'cat-other-label';
                let emoji = '💬';

                if (item.category.includes('参加')) {
                    badgeClass = 'badge-join';
                    catLabelClass = 'cat-join-label';
                    emoji = '👥';
                } else if (item.category.includes('内容') || item.category.includes('研修内容')) {
                    badgeClass = 'badge-content';
                    catLabelClass = 'cat-content-label';
                    emoji = '📖';
                } else if (item.category.includes('難易度')) {
                    badgeClass = 'badge-level';
                    catLabelClass = 'cat-level-label';
                    emoji = '📈';
                } else if (item.category.includes('日程')) {
                    badgeClass = 'badge-date';
                    catLabelClass = 'cat-date-label';
                    emoji = '📅';
                }

                // 対応ステータスのカラー
                const statusClass = item.status === '対応済み' ? 'status-done' : 'status-wait';

                const cardHtml = `
                    <div class="history-card" onclick="openInquiryDetail(${index})">
                        <div class="history-main-info">
                            <div class="history-badge ${badgeClass}">${emoji}</div>
                            <div class="history-texts">
                                <div class="history-row-top">
                                    <span class="history-name">${item.name}</span>
                                    <span class="history-time">${item.time}</span>
                                </div>
                                <div>
                                    <span class="history-category ${catLabelClass}">${item.category}</span>
                                    <span class="history-status-badge ${statusClass}">${item.status}</span>
                                </div>
