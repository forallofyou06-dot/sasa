        }

        // --- 5. フォーム送信処理 & 履歴へのダイレクトスタック追加 ---
        function handleFormSubmit(event) {
            event.preventDefault();

            // フォームから値を取得
            const name = document.getElementById('form-name').value;
            const empId = document.getElementById('form-empid').value;
            const email = document.getElementById('form-email').value;
            const category = document.getElementById('form-category').value;
            const detail = document.getElementById('form-detail').value;

            // 送信時の現在日時を生成
            const now = new Date();
            const year = now.getFullYear();
            const month = String(now.getMonth() + 1).padStart(2, '0');
            const date = String(now.getDate()).padStart(2, '0');
            const hours = String(now.getHours()).padStart(2, '0');
            const minutes = String(now.getMinutes()).padStart(2, '0');
            const seconds = String(now.getSeconds()).padStart(2, '0');
            const timeStr = `${year}-${month}-${date} ${hours}:${minutes}:${seconds}`;

            // 新規データオブジェクトを作成（直接反映）
            const newInquiry = {
                id: `Q${String(inquiryDatabase.length + 1).padStart(3, '0')}`,
                empId: empId,
                name: name,
                category: category,
                detail: detail,
                status: "未対応",
                reply: "ただいま担当者が確認中です。少々お待ちください。",
                time: timeStr
            };

            // データベース配列の先頭に追加
            inquiryDatabase.unshift(newInquiry);

            // 履歴リストを再描画
            renderHistoryList();

            // フォーム入力をリセット
            document.getElementById('contact-form').reset();

            // 履歴画面へ自動スクロール遷移
            switchTab('history', '問い合わせ履歴');
        }

        // --- 6. 詳細確認モーダル制御 ---
        function openInquiryDetail(index) {
            const data = inquiryDatabase[index];
            const modalBody = document.getElementById('modal-body-content');

            modalBody.innerHTML = `
                <div class="modal-item">
                    <div class="modal-label">問い合わせID / 日時</div>
                    <div class="modal-value">${data.id} &nbsp; [${data.time}]</div>
                </div>
                <div class="modal-item">
                    <div class="modal-label">氏名 (社員番号)</div>
                    <div class="modal-value">${data.name} (${data.empId})</div>
                </div>
                <div class="modal-item">
                    <div class="modal-label">カテゴリ</div>
                    <div class="modal-value"><span class="history-category cat-join-label" style="font-size:0.9rem; padding: 4px 12px;">${data.category}</span></div>
                </div>
                <div class="modal-item">
                    <div class="modal-label">問い合わせ内容詳細</div>
                    <div class="modal-value" style="background-color: #F8FAFC; padding: 12px; border-radius: 12px; margin-top:4px;">${data.detail}</div>
                </div>
                <div class="modal-item">
                    <div class="modal-label">現在の対応ステータス</div>
                    <div class="modal-value">
                        <span class="history-status-badge ${data.status === '対応済み' ? 'status-done' : 'status-wait'}" style="font-size:0.85rem; padding: 4px 10px;">
                            ${data.status}
                        </span>
                    </div>
                </div>
                <div class="modal-item">
                    <div class="modal-label">事務局からの回答</div>
                    <div class="modal-reply-box">
                        <div class="modal-value" style="font-style: italic;">${data.reply}</div>
                    </div>
                </div>
            `;

            toggleModal(true);
        }

        function toggleModal(show) {
            const modal = document.getElementById('detail-modal');
            if (show) {
                modal.classList.add('open');
            } else {
                modal.classList.remove('open');
            }
        }

        function closeModal(event) {
